# ============================================================
# DataSphere RH Guinée — Environment variables (.env.example)
# Copier en .env et adapter les valeurs
# ============================================================

# ━━ Application ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODE_ENV=development
APP_NAME=DataSphere RH Guinée
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ━━ Base de données PostgreSQL ━━━━━━━━━━━━━━━━━━━━━━━
DATABASE_URL=postgresql://dsrh:dsrh_dev_password@localhost:5432/dsrh_dev?schema=tenant_demo
DATABASE_URL_PUBLIC=postgresql://dsrh:dsrh_dev_password@localhost:5432/dsrh_dev?schema=public
SHADOW_DATABASE_URL=postgresql://dsrh:dsrh_dev_password@localhost:5432/dsrh_shadow

# ━━ Redis (cache, sessions, files d'attente) ━━━━━━━━━
REDIS_URL=redis://localhost:6379

# ━━ MinIO / S3 (stockage documents, bulletins PDF) ━━━
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=dsrh_minio_admin
S3_SECRET_KEY=dsrh_minio_dev_password
S3_BUCKET_PAYSPLIPS=payslips
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_AVATARS=avatars
S3_BUCKET_EXPORTS=exports

# ━━ Authentification JWT ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET=change-me-in-production-at-least-32-chars-long-please
JWT_ACCESS_EXPIRES=900       # 15 minutes (en secondes)
JWT_REFRESH_EXPIRES=604800   # 7 jours (en secondes)
JWT_ISSUER=datasphere-rh-gn
BCRYPT_COST=12

# ━━ 2FA TOTP ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TOTP_ISSUER=DataSphere RH Guinée
TOTP_WINDOW=1                # tolérance de 1 pas (30s)

# ━━ Notifications ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Twilio (WhatsApp Business + SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@datasphererh.gn
SENDGRID_FROM_NAME=DataSphere RH Guinée

# ━━ Rate limiting ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RATE_LIMIT_LOGIN_PER_IP=5    # 5 tentatives / minute / IP
RATE_LIMIT_API_PER_USER=100  # 100 req / min / user
RATE_LIMIT_API_PER_TENANT=1000

# ━━ Sécurité ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
COOKIE_SECRET=another-32-chars-long-secret-please-change
PASSWORD_RESET_EXPIRES=3600  # 1 heure (en secondes)
ACCOUNT_LOCK_THRESHOLD=5     # 5 échecs avant lock
ACCOUNT_LOCK_DURATION=900    # 15 minutes

# ━━ Observabilité ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SENTRY_DSN=
LOG_LEVEL=debug              # error | warn | info | debug
LOG_FORMAT=pretty            # pretty | json

# ━━ PDF generation (bulletins) ━━━━━━━━━━━━━━━━━━━━━━
PDF_GENERATION_CONCURRENCY=3
PDF_TEMPLATE_DIR=./templates/pdf
PDF_SIGNING_KEY=signing-secret-for-pdf-hashes

# ━━ Stripe / Paiements (optionnel, phase scale) ━━━━━
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
